# Copy to .env and adjust for your environment: cp .env.example .env
# docker compose reads this file automatically.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=internaldocs

# --- Host port mappings (left side = your machine) ---
FRONTEND_PORT=5173   # open http://localhost:5173
API_PORT=5210        # API + Swagger at http://localhost:5210
DB_PORT=5432         # Postgres on the host (change if 5432 is taken)

# --- JWT (Secret MUST be at least 32 characters) ---
JWT_SECRET=local-dev-jwt-secret-change-me-min-32-chars
JWT_ISSUER=InternalDocs
JWT_AUDIENCE=InternalDocs
JWT_EXPIRY_MINUTES=60

# --- Seeding ---
# true seeds demo documents in addition to the default users.
SEED_DEMO_DATA=true

# Seeded login accounts (created on first startup):
#   admin@internaldocs.local    / AdminPass123!
#   employee@internaldocs.local / EmployeePass123!
#   approver@internaldocs.local / ApproverPass123!
