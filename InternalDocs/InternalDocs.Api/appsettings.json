{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=internaldocs;Username=postgres;Password=change-me"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "your-azure-tenant-id",
    "ClientId": "your-azure-app-client-id",
    "Audience": "api://your-azure-app-client-id"
  },
  "Jwt": {
    "Secret": "YOUR_JWT_SECRET_HERE_MIN_32_CHARS",
    "Issuer": "InternalDocs",
    "Audience": "InternalDocs",
    "ExpiryMinutes": "60"
  }
}
