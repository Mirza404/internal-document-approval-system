# Copy this to .env or configure equivalent environment variables locally.

# Local development seeded accounts
ADMIN_EMAIL=admin@internaldocs.local
ADMIN_PASSWORD=AdminPass123!
EMPLOYEE_EMAIL=employee@internaldocs.local
EMPLOYEE_PASSWORD=EmployeePass123!

# Database
ConnectionStrings__DefaultConnection="Host=localhost;Port=5432;Database=internaldocs;Username=postgres;Password=change-me"

# Microsoft Entra ID
AzureAd__Instance=https://login.microsoftonline.com/
AzureAd__TenantId=YOUR_TENANT_ID
AzureAd__ClientId=YOUR_CLIENT_ID
AzureAd__Audience=api://YOUR_CLIENT_ID

# JWT settings
Jwt__Secret=YourSuperSecretJwtKeyAtLeast32CharsLong
Jwt__Issuer=InternalDocs
Jwt__Audience=InternalDocs
Jwt__ExpiryMinutes=60
